# Database
DATABASE_URL=postgresql://user:password@host:5432/sportsbook
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/sportsbook

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Blockchain (Fase 1)
CHAIN_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
SETTLEMENT_WALLET_PRIVATE_KEY=0x...
SPORTSBOOK_CONTRACT_ADDRESS=0x...

# Odds Provider (Fase 1 - ESPN es publico, pero reservar para futuro provider)
ODDS_PROVIDER_API_KEY=

# Quote config (Fase 1)
QUOTE_TTL_SECONDS=20
EVENT_LOCK_WINDOW_MINUTES=5
MAX_STAKE_USD=1000
MAX_PAYOUT_USD=10000

# JWT Admin (Fase 3)
JWT_SECRET=your-long-random-secret-here
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_in_production
ADMIN_FRONTEND_URL=http://localhost:5174

# Alert thresholds (Fase 3)
FEED_STALE_THRESHOLD_SECONDS=180
MANUAL_REVIEW_ALERT_THRESHOLD=1
SETTLEMENT_ALERT_THRESHOLD=1

# Settlement (Fase 2)
MAX_SETTLEMENT_ATTEMPTS=5
SETTLEMENT_WALLET_PRIVATE_KEY=0x...

# Grading (Fase 2)
GRADING_POLL_INTERVAL_SECONDS=30

# Parlays (Fase 4)
MAX_PARLAY_STAKE_USD=200
MAX_PARLAY_PAYOUT_USD=50000

# Cashout (Fase 4)
CASHOUT_MARGIN=0.05

# Promotions (Fase 4)
PROMOTIONS_ENABLED=true

# Ports
PORT_SPORTSBOOK_API=3000
PORT_ODDS_INGESTION=3001
PORT_BET_EXECUTION=3002
PORT_GRADING=3003
PORT_SETTLEMENT=3004
PORT_ADMIN=3005
